{
  "request": {
    "method": "POST",
    "url": "/provider/v1/execute",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.accountId",
        "equalToJson": "acc-500"
      }
    ]
  },
  "response": {
    "status": 500,
    "jsonBody": {
      "status": "ERROR",
      "code": "INTERNAL_SERVER_ERROR",
      "message": "The provider encountered an unexpected error"
    }
  }
}
