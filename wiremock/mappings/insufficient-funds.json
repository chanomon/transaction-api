{
  "request": {
    "method": "POST",
    "url": "/provider/v1/execute",
    "bodyPatterns": [
      {
        "matchesJsonPath": {
          "expression": "$.accountId",
          "equalTo": "acc-fail"
        }
      }
    ]
  },
  "response": {
    "status": 402,
    "jsonBody": {
      "status": "REJECTED",
      "code": "INSUFFICIENT_FUNDS",
      "message": "The account does not have enough balance to complete the transaction"
    }
  }
}
